@using System.Globalization
@using Crosscheck.Application.Projects
@using Crosscheck.Domain.Enums
@model ProjectManageViewModel
@{
    var usd = CultureInfo.GetCultureInfo("en-US");
    string Money(decimal v) => v.ToString("C0", usd);
    string Hrs(decimal h) => h.ToString("0.##");

    var project = Model.Project;
    var b = Model.Budget;
    var thresholdText = b is null ? "50, 75, 90" : string.Join(", ", b.AlertThresholds);
    var allocByRole = b?.RoleAllocations.ToDictionary(a => a.RoleId, a => a.Hours) ?? new Dictionary<Guid, decimal>();

    // With modules, hours live per module and the project totals roll up from them — the
    // budget card only carries the dollar figure and thresholds.
    var hasModules = Model.Modules.Count > 0;
    var moduleHoursTotal = Model.Modules.Sum(m => m.Module.EffectiveHours);
    var breakdownSingular = Terminology.Singular(project.BreakdownLabel);
    var breakdownPlural = Terminology.Plural(project.BreakdownLabel);

    // A service contract's monthly amount sizes the contract total from the project timeframe.
    // Initial render only — the card's script re-derives it live from the date inputs above.
    int? contractMonths = project.StartDate is not null && project.EndDate is not null
        ? BudgetService.ContractMonths(project.StartDate.Value, project.EndDate.Value)
        : null;
}

<div class="card panel-card">
    <div class="card-header">Budget</div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            A budget flags overrun on the <a asp-action="Dashboard" asp-route-id="@project.Id">dashboard</a> —
            it never blocks time entry or closes the project. Every change is kept as a revision.
        </p>

        <partial name="_TypeAndDates" model="Model.Form" />

        @if (b is not null)
        {
            <dl class="row mb-3 small">
                @if (b.MonthlyAmount is not null)
                {
                    <dt class="col-5 text-muted fw-normal">Monthly amount</dt>
                    <dd class="col-7 text-end fw-semibold">@Money(b.MonthlyAmount.Value)/mo</dd>
                }
                @if (b.Amount is not null)
                {
                    <dt class="col-5 text-muted fw-normal">@(b.MonthlyAmount is not null ? "Contract total" : project.Type == ProjectType.FixedRate ? "Contract amount" : "Dollar budget")</dt>
                    <dd class="col-7 text-end fw-semibold">@Money(b.Amount.Value)</dd>
                }
                @if (hasModules)
                {
                    <dt class="col-5 text-muted fw-normal">Hours budget</dt>
                    <dd class="col-7 text-end fw-semibold">@Hrs(moduleHoursTotal) hrs <span class="text-muted fw-normal">(from @breakdownPlural)</span></dd>
                }
                else if (b.Hours is not null)
                {
                    <dt class="col-5 text-muted fw-normal">Hours budget</dt>
                    <dd class="col-7 text-end fw-semibold">@Hrs(b.Hours.Value) hrs</dd>
                }
                <dt class="col-5 text-muted fw-normal">Alert at</dt>
                <dd class="col-7 text-end">@string.Join("%, ", b.AlertThresholds)%</dd>
            </dl>

            @if (!hasModules && b.RoleAllocations.Count > 0)
            {
                <div class="text-muted small text-uppercase mb-1">Hours by role</div>
                <ul class="list-unstyled small mb-3">
                    @foreach (var a in b.RoleAllocations.OrderBy(a => a.RoleName))
                    {
                        <li class="d-flex justify-content-between border-top py-1">
                            <span>@a.RoleName</span>
                            <span class="fw-semibold">@Hrs(a.Hours) hrs</span>
                        </li>
                    }
                </ul>
            }
        }
        else
        {
            <p class="text-muted small fst-italic mb-3">No budget set — the dashboard shows burn with nothing to measure against.</p>
        }

        <div class="inline-add">
            <div class="inline-add-title">@(b is null ? "Set budget" : "Revise budget")</div>
            <div class="row g-2">
                <div class="col-6" id="budget-amount-field">
                    <label class="form-label small mb-1" id="budget-amount-label">Dollar budget</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">$</span>
                        <input name="budgetAmount" type="number" step="0.01" min="0" class="form-control"
                               value="@(b?.MonthlyAmount is null ? b?.Amount?.ToString("0.##") : null)" placeholder="—" />
                    </div>
                </div>
                <div class="col-6" id="budget-monthly-field">
                    <label class="form-label small mb-1">Monthly amount</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">$</span>
                        <input name="budgetMonthlyAmount" type="number" step="0.01" min="0" class="form-control"
                               value="@(b?.MonthlyAmount?.ToString("0.##"))" placeholder="—" />
                        <span class="input-group-text">/mo</span>
                    </div>
                    <div class="form-text" id="contract-months-hint">
                        @if (contractMonths is int cm)
                        {
                            <text>Contract runs @project.StartDate!.Value.ToString("MMM d, yyyy") – @project.EndDate!.Value.ToString("MMM d, yyyy")
                            (@cm months) — the total budget is the monthly amount × @cm. Months can run heavy or light; burn is measured against the whole contract.</text>
                        }
                        else
                        {
                            <text>Set the start and end dates above so the monthly amount can size the contract total.</text>
                        }
                    </div>
                </div>
                @if (hasModules)
                {
                    <div class="col-6 d-flex align-items-end">
                        <div class="text-muted small">
                            Hours are managed per @breakdownSingular below — currently
                            rolling up to <strong>@Hrs(moduleHoursTotal) hrs</strong>.
                        </div>
                    </div>
                }
                else
                {
                    <div class="col-6" id="budget-hours-field">
                        <label class="form-label small mb-1">Hours budget <span class="text-muted">(optional)</span></label>
                        <input name="budgetHours" type="number" step="0.25" min="0" class="form-control form-control-sm"
                               value="@(b?.Hours?.ToString("0.##"))" placeholder="—" />
                    </div>
                }
                <div class="col-12">
                    <label class="form-label small mb-1">Alert thresholds (% burn)</label>
                    <input name="budgetThresholds" type="text" class="form-control form-control-sm" value="@thresholdText" />
                </div>
                @if (!hasModules && Model.BillableRoleOptions.Count > 0)
                {
                    <div class="col-12" id="budget-rolehours-field">
                        <label class="form-label small mb-1">Hours by role <span class="text-muted">(optional)</span></label>
                        <div class="text-muted small mb-2">Budget hours per billing role, e.g. Lead Developer 300, PM 10. Leave blank for roles you aren't capping. Overall hours default to the sum.</div>
                        <div class="row g-2">
                            @foreach (var option in Model.BillableRoleOptions)
                            {
                                var value = Guid.TryParse(option.Value, out var rid) && allocByRole.TryGetValue(rid, out var h)
                                    ? h.ToString("0.##")
                                    : "";
                                <div class="col-6 d-flex align-items-center gap-2">
                                    <label class="form-label small mb-0 flex-grow-1 text-truncate" for="roleHours-@option.Value">@option.Text</label>
                                    <input id="roleHours-@option.Value" name="roleHours[@option.Value]" type="number" step="0.25" min="0"
                                           value="@value" placeholder="—" class="form-control form-control-sm" style="width: 6rem" />
                                </div>
                            }
                        </div>
                    </div>
                }
                <div class="col-12">
                    <label class="form-label small mb-1">Reason <span class="text-muted">(optional)</span></label>
                    <input name="budgetReason" type="text" class="form-control form-control-sm" placeholder="e.g. SOW signed, change order #2" />
                </div>
            </div>
        </div>

        <script>
            // The budget asks only for what the project type needs: hourly shows an optional
            // dollar/hours cap, fixed rate asks for the contract amount, and a service contract
            // asks for the monthly amount (total = monthly × contract months). The type select
            // sits at the top of this card, so the fields follow it live.
            // Hidden inputs are disabled so they don't post.
            (function () {
                const type = document.getElementById('ProjectType');
                const fields = {
                    amount: document.getElementById('budget-amount-field'),
                    monthly: document.getElementById('budget-monthly-field'),
                    hours: document.getElementById('budget-hours-field'),
                    roleHours: document.getElementById('budget-rolehours-field'),
                };
                const amountLabel = document.getElementById('budget-amount-label');
                function toggle(el, show) {
                    if (!el) return;
                    el.classList.toggle('d-none', !show);
                    el.querySelectorAll('input').forEach(i => i.disabled = !show);
                }
                function sync() {
                    const service = type.value === 'ServiceContract';
                    toggle(fields.amount, !service);
                    toggle(fields.monthly, service);
                    toggle(fields.hours, !service);
                    toggle(fields.roleHours, !service);
                    amountLabel.textContent = type.value === 'FixedRate' ? 'Contract amount' : 'Dollar budget (optional)';
                }
                type.addEventListener('change', sync);
                sync();

                // The contract-months hint follows the date inputs above live (the server-rendered
                // text reflects only the saved dates). Same month math as BudgetService.ContractMonths:
                // inclusive calendar months, e.g. Jan 15 – Dec 1 = 12.
                const start = document.getElementById('StartDate');
                const end = document.getElementById('EndDate');
                const hint = document.getElementById('contract-months-hint');
                function syncHint() {
                    if (!hint || !start || !end) return;
                    if (!start.value || !end.value) {
                        hint.textContent = 'Set the start and end dates above so the monthly amount can size the contract total.';
                        return;
                    }
                    const s = new Date(start.value + 'T00:00:00');
                    const e = new Date(end.value + 'T00:00:00');
                    const months = (e.getFullYear() - s.getFullYear()) * 12 + e.getMonth() - s.getMonth() + 1;
                    if (months < 1) {
                        hint.textContent = 'The end date is before the start date — fix the dates above so the monthly amount can size the contract total.';
                        return;
                    }
                    const fmt = d => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                    hint.textContent = `Contract runs ${fmt(s)} – ${fmt(e)} (${months} month${months === 1 ? '' : 's'}) — ` +
                        `the total budget is the monthly amount × ${months}. Months can run heavy or light; ` +
                        'burn is measured against the whole contract.';
                }
                start?.addEventListener('change', syncHint);
                end?.addEventListener('change', syncHint);
                syncHint();
            })();
        </script>

        @if (Model.BudgetRevisions.Count > 0)
        {
            <div class="mt-3">
                <div class="text-muted small text-uppercase mb-1">History</div>
                <ul class="list-unstyled small mb-0">
                    @foreach (var rev in Model.BudgetRevisions)
                    {
                        var r = rev.Revision;
                        <li class="border-top py-2">
                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold">
                                    @(r.ToAmount is not null ? Money(r.ToAmount.Value) : "—")@(r.ToHours is not null ? $" · {Hrs(r.ToHours.Value)} hrs" : "")
                                </span>
                                <span class="text-muted">@r.RevisedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                            </div>
                            <div class="text-muted">
                                @Terminology.ProjectTypeLabel(r.ToType)
                                @if (r.FromAmount is not null && r.FromAmount != r.ToAmount)
                                {
                                    <span>· was @Money(r.FromAmount.Value)</span>
                                }
                                · @rev.RevisedByName
                            </div>
                            @if (!string.IsNullOrWhiteSpace(r.Reason))
                            {
                                <div class="fst-italic">"@r.Reason"</div>
                            }
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>
