@using System.Globalization
@using Crosscheck.Domain.Enums
@model ProjectManageViewModel
@{
    var usd = CultureInfo.GetCultureInfo("en-US");
    string Money(decimal v) => v.ToString("C0", usd);
    string Hrs(decimal h) => h.ToString("0.##");

    static string TypeLabel(BudgetType t) => t switch
    {
        BudgetType.FixedFee => "Fixed fee",
        BudgetType.TimeAndMaterialsCap => "T&M cap",
        BudgetType.HoursCap => "Hours cap",
        _ => t.ToString(),
    };

    var b = Model.Budget;
    var thresholdText = b is null ? "50, 75, 90" : string.Join(", ", b.AlertThresholds);
    var allocByRole = b?.RoleAllocations.ToDictionary(a => a.RoleId, a => a.Hours) ?? new Dictionary<Guid, decimal>();

    // With modules, hours live per module and the project totals roll up from them — the
    // budget card only carries the dollar figure and thresholds.
    var hasModules = Model.Modules.Count > 0;
    var moduleHoursTotal = Model.Modules.Sum(m => m.Module.EffectiveHours);
    var breakdownSingular = Crosscheck.Application.Projects.Terminology.Singular(Model.Project.BreakdownLabel);
    var breakdownPlural = Crosscheck.Application.Projects.Terminology.Plural(Model.Project.BreakdownLabel);
}

<div class="card panel-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Budget</span>
        @if (b is not null)
        {
            <span class="badge text-bg-secondary">@TypeLabel(b.Type)</span>
        }
    </div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            A budget flags overrun on the <a asp-action="Dashboard" asp-route-id="@Model.Project.Id">dashboard</a> —
            it never blocks time entry or closes the project. Every change is kept as a revision.
        </p>

        @if (b is not null)
        {
            <dl class="row mb-3 small">
                @if (b.Amount is not null)
                {
                    <dt class="col-5 text-muted fw-normal">Dollar budget</dt>
                    <dd class="col-7 text-end fw-semibold">@Money(b.Amount.Value)</dd>
                }
                @if (hasModules)
                {
                    <dt class="col-5 text-muted fw-normal">Hours budget</dt>
                    <dd class="col-7 text-end fw-semibold">@Hrs(moduleHoursTotal) hrs <span class="text-muted fw-normal">(from @breakdownPlural)</span></dd>
                }
                else if (b.Hours is not null)
                {
                    <dt class="col-5 text-muted fw-normal">Hours budget</dt>
                    <dd class="col-7 text-end fw-semibold">@Hrs(b.Hours.Value) hrs</dd>
                }
                <dt class="col-5 text-muted fw-normal">Alert at</dt>
                <dd class="col-7 text-end">@string.Join("%, ", b.AlertThresholds)%</dd>
            </dl>

            @if (!hasModules && b.RoleAllocations.Count > 0)
            {
                <div class="text-muted small text-uppercase mb-1">Hours by role</div>
                <ul class="list-unstyled small mb-3">
                    @foreach (var a in b.RoleAllocations.OrderBy(a => a.RoleName))
                    {
                        <li class="d-flex justify-content-between border-top py-1">
                            <span>@a.RoleName</span>
                            <span class="fw-semibold">@Hrs(a.Hours) hrs</span>
                        </li>
                    }
                </ul>
            }
        }
        else
        {
            <p class="text-muted small fst-italic mb-3">No budget set — the dashboard shows burn with nothing to measure against.</p>
        }

        <div class="inline-add">
            <div class="inline-add-title">@(b is null ? "Set budget" : "Revise budget")</div>
            <div class="row g-2">
                <div class="col-6">
                    <label class="form-label small mb-1">Type</label>
                    <select id="budget-type" name="budgetType" class="form-select form-select-sm">
                        @foreach (var t in new[] { BudgetType.FixedFee, BudgetType.TimeAndMaterialsCap, BudgetType.HoursCap })
                        {
                            <option value="@t" selected="@(b?.Type == t)">@TypeLabel(t)</option>
                        }
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label small mb-1">Break work down as</label>
                    <select name="BreakdownLabel" class="form-select form-select-sm"
                            title="What this work order calls its budget sections — display only, both work the same">
                        <option value="@BreakdownLabel.Module" selected="@(Model.Form.BreakdownLabel == BreakdownLabel.Module)">Modules</option>
                        <option value="@BreakdownLabel.Milestone" selected="@(Model.Form.BreakdownLabel == BreakdownLabel.Milestone)">Milestones</option>
                    </select>
                </div>
                <div class="col-6" id="budget-amount-field">
                    <label class="form-label small mb-1">Dollar amount</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">$</span>
                        <input name="budgetAmount" type="number" step="0.01" min="0" class="form-control"
                               value="@(b?.Amount?.ToString("0.##"))" placeholder="—" />
                    </div>
                </div>
                @if (hasModules)
                {
                    <div class="col-6 d-flex align-items-end">
                        <div class="text-muted small">
                            Hours are managed per @breakdownSingular below — currently
                            rolling up to <strong>@Hrs(moduleHoursTotal) hrs</strong>.
                        </div>
                    </div>
                }
                else
                {
                    <div class="col-6" id="budget-hours-field">
                        <label class="form-label small mb-1">Hours cap</label>
                        <input name="budgetHours" type="number" step="0.25" min="0" class="form-control form-control-sm"
                               value="@(b?.Hours?.ToString("0.##"))" placeholder="—" />
                    </div>
                }
                <div class="col-12">
                    <label class="form-label small mb-1">Alert thresholds (% burn)</label>
                    <input name="budgetThresholds" type="text" class="form-control form-control-sm" value="@thresholdText" />
                </div>
                @if (!hasModules && Model.BillableRoleOptions.Count > 0)
                {
                    <div class="col-12" id="budget-rolehours-field">
                        <label class="form-label small mb-1">Hours by role <span class="text-muted">(optional)</span></label>
                        <div class="text-muted small mb-2">Budget hours per billing role, e.g. Lead Developer 300, PM 10. Leave blank for roles you aren't capping. Overall hours default to the sum.</div>
                        <div class="row g-2">
                            @foreach (var option in Model.BillableRoleOptions)
                            {
                                var value = Guid.TryParse(option.Value, out var rid) && allocByRole.TryGetValue(rid, out var h)
                                    ? h.ToString("0.##")
                                    : "";
                                <div class="col-6 d-flex align-items-center gap-2">
                                    <label class="form-label small mb-0 flex-grow-1 text-truncate" for="roleHours-@option.Value">@option.Text</label>
                                    <input id="roleHours-@option.Value" name="roleHours[@option.Value]" type="number" step="0.25" min="0"
                                           value="@value" placeholder="—" class="form-control form-control-sm" style="width: 6rem" />
                                </div>
                            }
                        </div>
                    </div>
                }
                <div class="col-12">
                    <label class="form-label small mb-1">Reason <span class="text-muted">(optional)</span></label>
                    <input name="budgetReason" type="text" class="form-control form-control-sm" placeholder="e.g. SOW signed, change order #2" />
                </div>
            </div>
        </div>

        <script>
            // Only the fields the chosen budget type needs: dollar types (fixed fee / T&M cap)
            // show the dollar figure; an hours cap shows the hours fields. Hidden inputs are
            // disabled so they don't post. On a project with modules the hours fields are
            // already replaced by the per-@breakdownSingular rollup note.
            (function () {
                const type = document.getElementById('budget-type');
                const fields = {
                    amount: document.getElementById('budget-amount-field'),
                    hours: document.getElementById('budget-hours-field'),
                    roleHours: document.getElementById('budget-rolehours-field'),
                };
                function toggle(el, show) {
                    if (!el) return;
                    el.classList.toggle('d-none', !show);
                    el.querySelectorAll('input').forEach(i => i.disabled = !show);
                }
                function sync() {
                    const hoursCap = type.value === 'HoursCap';
                    toggle(fields.amount, !hoursCap);
                    toggle(fields.hours, hoursCap);
                    toggle(fields.roleHours, hoursCap);
                }
                type.addEventListener('change', sync);
                sync();
            })();
        </script>

        @if (Model.BudgetRevisions.Count > 0)
        {
            <div class="mt-3">
                <div class="text-muted small text-uppercase mb-1">History</div>
                <ul class="list-unstyled small mb-0">
                    @foreach (var rev in Model.BudgetRevisions)
                    {
                        var r = rev.Revision;
                        <li class="border-top py-2">
                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold">
                                    @(r.ToAmount is not null ? Money(r.ToAmount.Value) : "—")@(r.ToHours is not null ? $" · {Hrs(r.ToHours.Value)} hrs" : "")
                                </span>
                                <span class="text-muted">@r.RevisedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                            </div>
                            <div class="text-muted">
                                @TypeLabel(r.ToType)
                                @if (r.FromAmount is not null && r.FromAmount != r.ToAmount)
                                {
                                    <span>· was @Money(r.FromAmount.Value)</span>
                                }
                                · @rev.RevisedByName
                            </div>
                            @if (!string.IsNullOrWhiteSpace(r.Reason))
                            {
                                <div class="fst-italic">“@r.Reason”</div>
                            }
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>
