@using Crosscheck.Application.Employees
@using Crosscheck.Domain.Enums
@model IReadOnlyList<EmployeeSummary>
@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Employees</h1>
    <a class="btn btn-primary" asp-action="Create">New employee</a>
</div>

<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Type</th>
            <th>Roles</th>
            <th>Status</th>
            <th>Entra</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var e = item.Employee;
            <tr class="@(e.IsActive ? null : "table-secondary text-muted")">
                <td>@e.DisplayName</td>
                <td>@e.Email</td>
                <td>@(e.EmploymentType == EmploymentType.Subcontractor ? "1099 Subcontractor" : "Employee")</td>
                <td>
                    @if (item.RoleNames.Count == 0)
                    {
                        <span class="text-muted">none</span>
                    }
                    @foreach (var role in item.RoleNames)
                    {
                        <span class="badge text-bg-primary me-1">@role</span>
                    }
                </td>
                <td>
                    <span class="badge @(e.IsActive ? "text-bg-success" : "text-bg-secondary")">
                        @(e.IsActive ? "Active" : "Inactive")
                    </span>
                </td>
                <td>
                    <span class="badge @(e.EntraOid is null ? "text-bg-warning" : "text-bg-success")"
                          title="@(e.EntraOid is null ? "Will link on first sign-in" : "Linked to Entra ID")">
                        @(e.EntraOid is null ? "Not linked" : "Linked")
                    </span>
                </td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@e.Id">Manage</a>
                </td>
            </tr>
        }
    </tbody>
</table>
