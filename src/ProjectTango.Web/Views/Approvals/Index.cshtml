@using ProjectTango.Domain.Enums
@model ApprovalsViewModel
@{
    ViewData["Title"] = "Approvals";
    string Fmt(decimal h) => h.ToString("0.##");
}

<h1 class="h3 mb-1">Time Approvals</h1>
<p class="text-muted">
    Approving is the billing decision: keep or trim <em>billed</em> hours (worked hours never change),
    then approve. Approved entries can be returned to open for correction until they are invoiced.
</p>

@if (TempData["Notice"] is string notice)
{
    <div class="alert alert-success">@notice</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<form asp-action="Index" method="get" class="card panel-card mb-4">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small text-muted mb-1">Project</label>
                <select name="projectId" class="form-select" asp-items="Model.ProjectOptions">
                    <option value="">— choose a project —</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted mb-1">From</label>
                <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted mb-1">To</label>
                <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">Go</button>
            </div>
        </div>
    </div>
</form>

@if (Model.ProjectId is null)
{
    <div class="alert alert-info">Choose a project and date range to review its time.</div>
    return;
}

<div class="d-flex flex-wrap align-items-center gap-3 mb-3">
    <h2 class="h5 mb-0">@Model.ProjectLabel</h2>
    <span class="text-muted small">@Model.From.ToString("MMM d") – @Model.To.ToString("MMM d, yyyy")</span>
    <span class="badge text-bg-warning-subtle text-warning-emphasis border border-warning-subtle">@Model.OpenCount open</span>
    <span class="badge text-bg-success-subtle text-success-emphasis border border-success-subtle">@Model.ApprovedCount approved</span>
    @if (Model.InvoicedCount > 0)
    {
        <span class="badge text-bg-secondary">@Model.InvoicedCount invoiced</span>
    }
    @if (Model.OpenCount > 0)
    {
        <form asp-action="ApproveAll" method="post" class="ms-auto m-0">
            <input type="hidden" name="projectId" value="@Model.ProjectId" />
            <input type="hidden" name="from" value="@Model.From.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="to" value="@Model.To.ToString("yyyy-MM-dd")" />
            <button type="submit" class="btn btn-success">Approve all @Model.OpenCount open</button>
        </form>
    }
</div>

@if (Model.Entries.Count == 0)
{
    <div class="alert alert-info">No time entries in this range.</div>
    return;
}

<div class="card panel-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Date</th>
                    <th>Employee</th>
                    <th>Billing role</th>
                    <th class="text-end">Worked</th>
                    <th class="text-end">Billed</th>
                    <th>Status</th>
                    <th class="text-end pe-3">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Entries.OrderBy(e => e.Entry.EntryDate).ThenBy(e => e.EmployeeName))
                {
                    var e = item.Entry;
                    <tr>
                        <td class="ps-3">@e.EntryDate.ToString("ddd MMM d")</td>
                        <td>@item.EmployeeName</td>
                        <td>
                            @item.BillingRoleName
                            @if (!e.IsBillable)
                            {
                                <span class="badge text-bg-light text-muted ms-1">non-billable</span>
                            }
                        </td>
                        <td class="text-end">@Fmt(e.HoursWorked)</td>
                        <td class="text-end">@Fmt(e.HoursBilled)</td>
                        <td>
                            @switch (e.Status)
                            {
                                case TimeEntryStatus.Open:
                                    <span class="badge text-bg-warning-subtle text-warning-emphasis border border-warning-subtle">open</span>
                                    break;
                                case TimeEntryStatus.Approved:
                                    <span class="badge text-bg-success-subtle text-success-emphasis border border-success-subtle">approved</span>
                                    break;
                                case TimeEntryStatus.Invoiced:
                                    <span class="badge text-bg-secondary">invoiced</span>
                                    break;
                            }
                        </td>
                        <td class="text-end pe-3">
                            @if (e.Status == TimeEntryStatus.Open)
                            {
                                <form asp-action="Approve" method="post" class="d-inline-flex gap-1 align-items-center justify-content-end">
                                    <input type="hidden" name="entryId" value="@e.Id" />
                                    <input type="hidden" name="projectId" value="@Model.ProjectId" />
                                    <input type="hidden" name="from" value="@Model.From.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="to" value="@Model.To.ToString("yyyy-MM-dd")" />
                                    <input type="number" name="billedHours" value="@Fmt(e.HoursBilled)" min="0" max="@Fmt(e.HoursWorked)"
                                           step="0.25" class="form-control form-control-sm" style="width:5rem" title="Billed hours" />
                                    <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                </form>
                            }
                            else if (e.Status == TimeEntryStatus.Approved)
                            {
                                <form asp-action="Unapprove" method="post" class="d-inline">
                                    <input type="hidden" name="entryId" value="@e.Id" />
                                    <input type="hidden" name="projectId" value="@Model.ProjectId" />
                                    <input type="hidden" name="from" value="@Model.From.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="to" value="@Model.To.ToString("yyyy-MM-dd")" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary"
                                            title="Return this entry to open for correction">Un-approve</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">locked</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
